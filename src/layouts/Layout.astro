
---
// Inject the global utility styles layer at the top of your layout
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Senior GenAI & Data Engineer Portfolio" } = Astro.props;
---


<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body class="bg-slate-950 text-slate-100 min-h-screen antialiased selection:bg-orange-500/30 selection:text-orange-400">
		<div class="max-w-4xl mx-auto px-6 py-16">
			<header class="flex justify-between items-center mb-16 border-b border-slate-800/60 pb-6">
				<a href="/" class="font-medium tracking-tight text-lg hover:text-orange-400 transition-colors">
					alpha9934<span class="text-orange-500">.dev</span>
				</a>
				<nav class="flex gap-6 text-sm font-medium text-slate-400">
					<a href="/" class="hover:text-slate-100 transition-colors">Home</a>
					<a href="/projects" class="hover:text-slate-100 transition-colors">Projects</a>
					<a href="https://github.com/alpha9934" target="_blank" class="hover:text-slate-100 transition-colors">GitHub</a>
				</nav>
			</header>

			<main>
				<slot />
			</main>

			<footer class="mt-24 pt-8 border-t border-slate-900 text-center text-xs text-slate-600 font-mono">
				© {new Date().getFullYear()} · Built with Astro + Tailwind
			</footer>
		</div>
	</body>
</html>