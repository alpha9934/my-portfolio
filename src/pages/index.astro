---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';

// Query the storage layers and sort them dynamically safely
const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => {
  const dateB = b.data.publishDate ? b.data.publishDate.valueOf() : 0;
  const dateA = a.data.publishDate ? a.data.publishDate.valueOf() : 0;
  return dateB - dateA;
});
---

<Layout title="Abhishek Kumar Gupta | Senior GenAI & Data Engineer Portfolio">
	<section class="mb-16">
		<p class="font-mono text-xs uppercase tracking-widest text-orange-500 mb-2">Production Engineering</p>
		<h1 class="text-4xl md:text-5xl font-black text-slate-100 tracking-tight leading-none mb-4">
			Building Reliable,<br>Production-Grade AI Systems.
		</h1>
		<p class="text-base text-slate-400 max-w-2xl leading-relaxed">
			I specialize in enterprise-grade Generative AI architecture, Agentic RAG pipelines, and scalable data orchestration. I eliminate production failures and build strict monitoring gates to make language models enterprise-safe.
		</p>
	</section>

	<section>
		<div class="flex justify-between items-baseline mb-6">
			<h2 class="text-xl font-bold tracking-tight text-slate-200">Featured Production Systems</h2>
			<a href="/projects" class="text-xs font-mono text-slate-500 hover:text-orange-400 transition-colors">View All</a>
		</div>
		
		<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
			{sortedProjects.map((project) => (
				<ProjectCard 
					title={project.data.title}
					description={project.data.description}
					tags={project.data.tags}
					slug={project.slug}
					category={project.data.category}
					githubUrl={project.data.githubUrl}
				/>
			))}
		</div>
	</section>
</Layout>